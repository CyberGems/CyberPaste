{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "CyberPaste",
  "version": "1.5.0",
  "identifier": "me.cybergems.cyberpaste",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CyberPaste",
        "width": 1920,
        "height": 540,
        "minWidth": 600,
        "minHeight": 280,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "center": false,
        "skipTaskbar": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/CyberPaste/images/**",
          "$LOCALDATA/CyberPaste/images/**"
        ]
      },
      "capabilities": [
        "default"
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "CyberGems",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CyberGems/CyberPaste/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDAxNDhBMzY2RUIxMTkzQTcKUldTbmt4SHJacU5JQVEzdWxCUXNWcE9hN2N2QzhzSjB3OC9RT0lPbVNUSXR2YlZQRWxsaE8ydzMK"
    }
  }
}
